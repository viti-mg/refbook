{
  "name": "refbook",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "type-check": "turbo run type-check",
    "clean": "turbo run clean && rm -rf node_modules",
    "dev:app": "turbo run dev --filter=@apps/app",
    "dev:web": "turbo run dev --filter=@apps/web",
    "build:app": "turbo run build --filter=@apps/app",
    "build:web": "turbo run build --filter=@apps/web",
    "test:app": "turbo run test --filter=@apps/app",
    "test:watch": "turbo run test:watch --filter=@apps/app",
    "test:ui": "turbo run test:ui --filter=@apps/app",
    "test:coverage": "turbo run test:coverage --filter=@apps/app",
    "test:e2e": "turbo run test:e2e --filter=@apps/app",
    "test:e2e:ui": "turbo run test:e2e:ui --filter=@apps/app",
    "test:e2e:debug": "turbo run test:e2e:debug --filter=@apps/app",
    "lint:fix": "turbo run lint:fix",
    "format": "turbo run format",
    "format:check": "turbo run format:check",
    "generate-routes": "turbo run generate-routes --filter=@apps/app",
    "preview": "turbo run preview --filter=@apps/app"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "turbo": "^1.10.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss"
    ]
  },
  "dependencies": {
    "zod": "^4.0.0"
  }
}
